{
  "name": "slipstream",
  "version": "1.0.0",
  "description": "macOS floating translation and explanation assistant",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron . --dev\"",
    "build": "vite build && electron-builder",
    "start": "electron .",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{js,jsx,css,html}'"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "electron-store": "^8.1.0",
    "@anthropic-ai/sdk": "^0.20.0",
    "openai": "^4.20.0"
  },
  "build": {
    "appId": "com.slipstream.app",
    "productName": "Slipstream",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/shared/**/*",
      "preload.js",
      "scripts/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron-builder": "^24.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.0"
  }
}
