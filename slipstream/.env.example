# Copy these into your shell or CI secrets before running a signed release.
# Do not put real credentials in this file.
# Recommended for CI: App Store Connect API key.
APPLE_API_KEY=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=

# Alternative: Apple ID app-specific password.
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_TEAM_ID=

# Alternative: notarytool keychain profile.
# APPLE_KEYCHAIN=
# APPLE_KEYCHAIN_PROFILE=
